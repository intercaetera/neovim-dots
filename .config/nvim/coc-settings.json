{
	"elixir.pathToElixirLS": "~/git/elixirls/language_server.sh",
	"eslint.autoFixOnSave": true,
	"diagnostic.enable": true,
  "suggest.noselect": true,
  "languageserver": {
    "elmLS": {
      "command": "elm-language-server",
      "filetypes": ["elm"],
      "rootPatterns": ["elm.json"],
			"enable": true
    }
  }
}
